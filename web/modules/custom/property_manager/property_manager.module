<?php

/**
 * @file
 * Property Manager — plataforma de gestión de propiedades inmobiliarias.
 */

use Drupal\Component\Utility\Html;
use Drupal\Core\Form\FormStateInterface;
use Drupal\node\NodeInterface;

/**
 * Implements hook_node_presave().
 *
 * Auto-generates field_codigo on Inmueble nodes when the field is empty.
 * The counter lives in State API (not Config) so it never resets on config
 * import/export between environments.
 */
function property_manager_node_presave(NodeInterface $node) {
  if ($node->bundle() !== 'inmueble' || !$node->get('field_codigo')->isEmpty()) {
    return;
  }

  $config = \Drupal::config('property_manager.settings');
  $prefix = $config->get('codigo_prefijo') ?? 'PROP';
  $separator = $config->get('codigo_separador') ?? '-';
  $digits = (int) ($config->get('codigo_digitos') ?? 5);

  $state = \Drupal::state();
  $counter = $state->get('property_manager.ultimo_codigo', 0) + 1;
  $state->set('property_manager.ultimo_codigo', $counter);

  $node->set('field_codigo', $prefix . $separator . str_pad($counter, $digits, '0', STR_PAD_LEFT));
}

/**
 * Implements hook_form_alter().
 *
 * On create: hides field_codigo — it's auto-generated on save.
 * On edit: shows it read-only so the editor can see the assigned code.
 * Cascading location fields: Departamento visible only after País,
 * Ciudad visible only after Departamento.
 */
function property_manager_form_alter(array &$form, FormStateInterface $form_state, string $form_id) {
  if (!in_array($form_id, ['node_inmueble_form', 'node_inmueble_edit_form'], TRUE)) {
    return;
  }

  // --- Código auto-generado ---
  if ($form_id === 'node_inmueble_form') {
    // CREATE: aviso de que el código se genera al guardar, con preview del formato.
    $config = \Drupal::config('property_manager.settings');
    $prefix = $config->get('codigo_prefijo') ?? 'PROP';
    $separator = $config->get('codigo_separador') ?? '-';
    $digits = (int) ($config->get('codigo_digitos') ?? 5);
    $needs_setup = \Drupal::state()->get('property_manager.needs_setup', FALSE);
    if ($needs_setup || $prefix === 'PROP') {
      \Drupal::messenger()->addWarning(t(
        'El módulo no ha sido configurado. <a href=":url">Define el prefijo del código</a> antes de crear inmuebles.',
        [':url' => \Drupal\Core\Url::fromRoute('property_manager.settings')->toString()]
      ));
    }
    $next = \Drupal::state()->get('property_manager.ultimo_codigo', 0) + 1;
    $preview = Html::escape($prefix . $separator . str_pad($next, $digits, '0', STR_PAD_LEFT));
    $form['codigo_notice'] = [
      '#type'   => 'markup',
      '#markup' => '<div class="pm-codigo pm-codigo--pending" role="note">'
        . '<span class="pm-codigo__icon" aria-hidden="true">🔖</span>'
        . '<div class="pm-codigo__body">'
        . '<strong class="pm-codigo__label">' . t('Código del inmueble') . '</strong>'
        . '<span class="pm-codigo__value">' . $preview . '</span>'
        . '<span class="pm-codigo__hint">' . t('Se asignará automáticamente al guardar.') . '</span>'
        . '</div></div>',
      '#weight' => -5,
    ];
  }
  else {
    // EDIT: mostrar el código asignado como referencia no editable.
    $codigo = $form_state->getFormObject()->getEntity()->get('field_codigo')->value ?? '';
    $form['codigo_display'] = [
      '#type'   => 'markup',
      '#markup' => '<div class="pm-codigo pm-codigo--assigned" role="note">'
        . '<span class="pm-codigo__icon" aria-hidden="true">🔖</span>'
        . '<div class="pm-codigo__body">'
        . '<strong class="pm-codigo__label">' . t('Código') . '</strong>'
        . '<span class="pm-codigo__value">' . Html::escape($codigo) . '</span>'
        . '<span class="pm-codigo__hint">' . t('Asignado automáticamente · no editable') . '</span>'
        . '</div></div>',
      '#weight' => -5,
    ];
  }

  // --- Cascada de ubicación ---
  if (isset($form['field_departamento'])) {
    $form['field_departamento']['#states'] = [
      'visible' => ['select[name="field_pais"]' => ['!value' => '_none']],
    ];
  }
  if (isset($form['field_ciudad'])) {
    $form['field_ciudad']['#states'] = [
      'visible' => ['select[name="field_departamento"]' => ['!value' => '_none']],
    ];
  }

  // Bloquear guardado si el módulo no ha sido configurado.
  $form['#validate'][] = '_property_manager_validate_configuracion';

  // CSS del formulario.
  $form['#attached']['library'][] = 'property_manager/form';

  // Registrar after_build para organizar secciones DESPUÉS de todo el procesamiento del form display.
  $form['#after_build'][] = '_property_manager_form_after_build';
}

/**
 * Validate: impide guardar inmuebles si el módulo no ha sido configurado.
 */
function _property_manager_validate_configuracion(array &$form, FormStateInterface $form_state): void {
  $config = \Drupal::config('property_manager.settings');
  $prefix = $config->get('codigo_prefijo') ?? 'PROP';
  if ($prefix === 'PROP') {
    $url = \Drupal\Core\Url::fromRoute('property_manager.settings')->toString();
    $form_state->setError(
      $form,
      t('No es posible guardar inmuebles hasta que el módulo esté configurado. <a href=":url">Define el prefijo del código</a> antes de continuar.', [':url' => $url])
    );
  }
}

/**
 * #after_build callback: reorganizes the Inmueble form AFTER all form display
 * processing is complete, so our weights are truly final.
 */
function _property_manager_form_after_build(array $form, FormStateInterface $form_state): array {
  $form_id = $form_state->getFormObject()->getFormId();
  _property_manager_build_form_sections($form, $form_id);
  return $form;
}

/**
 * Reorganizes the Inmueble form into collapsible <details> sections.
 * Called from #after_build so weights cannot be overridden by form display.
 */
function _property_manager_build_form_sections(array &$form, string $form_id): void {
  // Título y descripción fuera de cualquier sección, con pesos muy bajos
  // para garantizar que aparezcan primero independientemente del form display.
  if (isset($form['title'])) {
    $form['title']['#weight'] = -1000;
  }
  if (isset($form['body'])) {
    $form['body']['#weight'] = -900;
  }

  // Siempre ocultar el campo real field_codigo del form display:
  // lo controlamos nosotros con codigo_notice / codigo_display.
  if (isset($form['field_codigo'])) {
    $form['field_codigo']['#access'] = FALSE;
  }

  // Área: aceptar coma como separador decimal (estándar colombiano).
  if (isset($form['field_area']['widget'][0]['value'])) {
    $form['field_area']['widget'][0]['value']['#description'] = t('Puede usar punto o coma como separador decimal. Ej: 96.38 o 96,38');
    $form['field_area']['widget'][0]['value']['#element_validate'][] = '_property_manager_validate_decimal';
  }

  $codigo_key = $form_id === 'node_inmueble_form' ? 'codigo_notice' : 'codigo_display';

  // Helper: extrae claves del formulario raíz y las retorna como hijos.
  $move = function (array $keys) use (&$form): array {
    $group = [];
    foreach ($keys as $key) {
      if (isset($form[$key])) {
        $group[$key] = $form[$key];
        unset($form[$key]);
      }
    }
    return $group;
  };

  // 1. Información básica (abierto) — peso positivo → aparece después de título/body
  $form['grupo_basica'] = [
    '#type'   => 'details',
    '#title'  => t('Información básica'),
    '#open'   => TRUE,
    '#weight' => 10,
  ] + $move([$codigo_key, 'field_tipo_oferta', 'field_tipo_inmueble', 'field_estado_inmueble', 'field_precio']);

  // 2. Ubicación (abierto)
  $form['grupo_ubicacion'] = [
    '#type'   => 'details',
    '#title'  => t('Ubicación'),
    '#open'   => TRUE,
    '#weight' => 20,
  ] + $move(['field_pais', 'field_departamento', 'field_ciudad', 'field_direccion', 'field_barrio', 'field_zona']);

  // 3. Características (abierto)
  $form['grupo_caracteristicas'] = [
    '#type'   => 'details',
    '#title'  => t('Características'),
    '#open'   => TRUE,
    '#weight' => 30,
  ] + $move(['field_habitaciones', 'field_banos', 'field_parqueadero', 'field_area', 'field_estrato']);

  // 4. Amenidades (abierto)
  $form['grupo_amenidades'] = [
    '#type'   => 'details',
    '#title'  => t('Amenidades'),
    '#open'   => TRUE,
    '#weight' => 40,
  ] + $move(['field_caract_int', 'field_caract_ext']);

  // 5. Multimedia (cerrado)
  $form['grupo_multimedia'] = [
    '#type'   => 'details',
    '#title'  => t('Multimedia'),
    '#open'   => FALSE,
    '#weight' => 50,
  ] + $move(['field_fotos', 'field_video']);

  // 6. Información asociada (cerrado)
  $form['grupo_admin'] = [
    '#type'   => 'details',
    '#title'  => t('Información asociada'),
    '#open'   => FALSE,
    '#weight' => 60,
  ] + $move(['field_agente']);
}

/**
 * Element validate: converts comma to period so Drupal accepts Colombian decimals.
 */
function _property_manager_validate_decimal(array &$element, FormStateInterface $form_state, array &$complete_form): void {
  $value = $element['#value'];
  if (is_string($value) && str_contains($value, ',')) {
    $value = str_replace(',', '.', $value);
    $form_state->setValueForElement($element, $value);
  }
}

/**
 * Implements hook_requirements().
 */
function property_manager_requirements(string $phase): array {
  $requirements = [];

  if ($phase === 'runtime') {
    $needs_setup = \Drupal::state()->get('property_manager.needs_setup', FALSE);

    if ($needs_setup) {
      $requirements['property_manager_setup'] = [
        'title' => t('Property Manager'),
        'description' => t('El módulo se instaló con los valores por defecto. <a href=":url">Revisa y ajusta la configuración inicial</a>.', [
          ':url' => \Drupal\Core\Url::fromRoute('property_manager.settings')->toString(),
        ]),
        'severity' => REQUIREMENT_INFO,
        'value' => t('Configuración inicial pendiente'),
      ];
    }
    else {
      $requirements['property_manager_setup'] = [
        'title' => t('Property Manager'),
        'value' => t('Configurado'),
        'severity' => REQUIREMENT_OK,
      ];
    }
  }

  return $requirements;
}

/**
 * Implements hook_node_view().
 *
 * Attaches node styles only when viewing an Inmueble.
 */
function property_manager_node_view(array &$build, NodeInterface $node, $display, $view_mode) {
  if ($node->bundle() === 'inmueble') {
    $build['#attached']['library'][] = 'property_manager/node';
  }
}

/**
 * Implements hook_preprocess_field().
 *
 * For field_caract_int and field_caract_ext, renders ALL allowed values
 * with ✓ (selected) or ✗ (not selected) so the visitor sees the full list.
 */
function property_manager_preprocess_field(array &$variables) {
  $field_name = $variables['field_name'] ?? '';
  if (!in_array($field_name, ['field_caract_int', 'field_caract_ext'], TRUE)) {
    return;
  }
  if (($variables['element']['#view_mode'] ?? '') === 'form') {
    return;
  }

  /** @var \Drupal\Core\Field\FieldItemListInterface $items */
  $items = $variables['element']['#items'];
  $field_def = $items->getFieldDefinition();
  $allowed_values = $field_def->getSetting('allowed_values');

  // Collect selected keys.
  $selected = [];
  foreach ($items as $item) {
    $selected[$item->value] = TRUE;
  }

  // Rebuild items array showing all options.
  $variables['items'] = [];
  foreach ($allowed_values as $key => $label) {
    $is_selected = isset($selected[$key]);
    $variables['items'][] = [
      'attributes' => new \Drupal\Core\Template\Attribute([
        'class' => ['pm-caract-item', $is_selected ? 'pm-caract--yes' : 'pm-caract--no'],
      ]),
      'content' => ['#markup' => Html::escape($label)],
      '_selected' => $is_selected,
    ];
  }
}
